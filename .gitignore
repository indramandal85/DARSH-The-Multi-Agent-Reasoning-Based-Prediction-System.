# ── Python virtual environment ──────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Environment variables (API keys — NEVER commit these) ───────────────────
.env
.env.local
.env.production

# ── Runtime data (generated by the system — too large for git) ──────────────
data/simulations/
data/chroma/
data/graphs/*.json
data/reports/

# ── Keep the data folder structure but not the contents ─────────────────────
!data/inputs/
!data/inputs/rbi_article.txt

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── VS Code settings ─────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── Node.js (Vue frontend) ───────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Python build artifacts ───────────────────────────────────────────────────
*.egg-info/
dist/
build/
.eggs/

# ── Testing and coverage ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Jupyter notebooks checkpoints ───────────────────────────────────────────
.ipynb_checkpoints/

# ── Ollama models (stored elsewhere on system) ───────────────────────────────
*.gguf
*.bin
models/

Documentation/
use.txt
